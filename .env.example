# ─── Appmax IA FAQ — Variáveis de Ambiente ───────────────────────────────────
# Copie este arquivo para ".env" e preencha os valores.
# NUNCA commite o arquivo .env no GitHub.

# ── OBRIGATÓRIO ──────────────────────────────────────────────────────────────
# Chave de API da Anthropic — obtenha em: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-COLE-SUA-CHAVE-AQUI

# ── USUÁRIOS DE DEMONSTRAÇÃO (MVP) ───────────────────────────────────────────
# Senha comum usada nos 3 logins de demo (suporte / tecnico / gestor)
# Altere para algo seguro antes da apresentação
DEMO_PASS=appmax@2025

# ── USUÁRIOS PERSONALIZADOS (opcional) ───────────────────────────────────────
# Se quiser definir usuários pelo .env ao invés do código,
# serialize o dicionário em JSON e coloque aqui:
# USERS_JSON={"email@appmax.com":{"nome":"Nome","equipe":"Time","nivel":1,"senha":"senha123"}}

# ── GOOGLE SHEETS (opcional — para registro de dúvidas sem resposta) ─────────
# JSON da conta de serviço Google (tudo em uma linha)
# GOOGLE_CREDENTIALS={"type":"service_account","project_id":"...","private_key":"..."}
